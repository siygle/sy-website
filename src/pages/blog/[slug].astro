---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Comments from '~/components/Comments.astro';
import { slugifyTag } from '~/lib/tags';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(dateString: string): string {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const tags = Array.isArray(post.data.tags) ? post.data.tags : [];
---

<BaseLayout
  title={`${post.data.title} - Sy Lee`}
  description={post.data.description || ''}
>
  <article class="max-w-2xl lg:max-w-3xl mx-auto px-5 py-12" data-pagefind-body>
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4" data-pagefind-meta="title">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-3">
        <time class="text-sm text-gray-500">
          {formatDate(post.data.date)}
        </time>
        {
          tags.length > 0 && (
            <>
              <span class="text-gray-300">&middot;</span>
              <div class="flex flex-wrap gap-2">
                {tags.map((tag: string) => (
                  <a
                    href={`/tags/${slugifyTag(tag)}`}
                    class="text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded
                           hover:bg-teal-50 hover:text-teal-700 transition-colors"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            </>
          )
        }
      </div>
    </header>

    <div class="prose prose-lg">
      <Content />
    </div>
  </article>

  <Comments blueskyUri={post.data.blueskyUri} />

  <script>
    function initProgressBar() {
      const existing = document.getElementById('reading-progress');
      if (existing) existing.remove();

      const article = document.querySelector('article');
      if (!article) return;

      const bar = document.createElement('div');
      bar.id = 'reading-progress';
      bar.setAttribute('aria-hidden', 'true');
      Object.assign(bar.style, {
        position: 'fixed',
        top: '0',
        left: '0',
        height: '2px',
        width: '0%',
        backgroundColor: '#14b8a6',
        zIndex: '50',
        transition: 'width 100ms ease-out',
        pointerEvents: 'none',
      });
      document.body.appendChild(bar);

      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight =
          document.documentElement.scrollHeight - window.innerHeight;
        if (docHeight <= 0) {
          bar.style.width = '100%';
          return;
        }
        const progress = Math.min((scrollTop / docHeight) * 100, 100);
        bar.style.width = `${progress}%`;
      }

      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }

    initProgressBar();
    document.addEventListener('astro:after-swap', initProgressBar);
  </script>
</BaseLayout>
